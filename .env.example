# ============================================================
# MG-YT-Dashboard — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# All VITE_ prefixed variables are bundled into the frontend.
#
# These can ALSO be set at runtime via the Settings Drawer
# (stored in localStorage) — no redeploy required for changes.
# ============================================================

# -------------------------------------------------------
# 🔑 REQUIRED — Google OAuth Client ID
# Get from: https://console.cloud.google.com/
#   Credentials → OAuth 2.0 Client IDs (Web application)
#   Add your domain to "Authorized JavaScript origins"
#   Add /auth/callback to "Authorized redirect URIs"
# -------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# -------------------------------------------------------
# 🔑 REQUIRED — Google API Key (for Drive Picker + YouTube Data API)
# Get from: https://console.cloud.google.com/
#   APIs & Services → Credentials → API Keys
#   Restrict to: YouTube Data API v3, Google Drive API, Google Picker API
# -------------------------------------------------------
VITE_GOOGLE_API_KEY=your_google_api_key_here

# -------------------------------------------------------
# 📺 YouTube Configuration
# Channel ID: YouTube Studio → Customization → Channel URL
#   The part after /channel/ (starts with UC...)
# -------------------------------------------------------
VITE_YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------
# 📋 Google Apps Script Backend URL
# Deploy Code.gs as a Web App in Google Apps Script
# Execute as: Me | Who has access: Anyone
# -------------------------------------------------------
VITE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# -------------------------------------------------------
# 📁 Google Drive Upload Folder ID
# Open the target Drive folder → copy ID from URL
#   drive.google.com/drive/folders/FOLDER_ID_HERE
# Optional — files go to root Drive if not set
# -------------------------------------------------------
VITE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# -------------------------------------------------------
# 📺 YouTube Playlist ID (optional)
# If set, newly published videos are added to this playlist
# Get from: studio.youtube.com → Playlists
# -------------------------------------------------------
VITE_YOUTUBE_PLAYLIST_ID=PLxxxxxxxxxxxxxxxxxxxxxx
