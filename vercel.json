{
    "rewrites": [
        {
            "source": "/drive-proxy/:path*",
            "destination": "https://www.googleapis.com/:path*"
        },
        {
            "source": "/yt-upload-proxy/:path*",
            "destination": "https://www.googleapis.com/:path*"
        },
        {
            "source": "/yt-api-proxy/:path*",
            "destination": "https://www.googleapis.com/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}